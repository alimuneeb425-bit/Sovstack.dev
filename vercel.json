{
  "version": 2,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Content-Security-Policy", "value": "upgrade-insecure-requests" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
